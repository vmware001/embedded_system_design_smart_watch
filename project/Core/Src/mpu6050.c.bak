#include "mpu6050.h"
#include "bluetooth.h"
#include <math.h>
#include <stdio.h>

static I2C_HandleTypeDef *mpu6050_i2c;
float g_mpu_temp = 0.0f;

static volatile uint32_t step_count = 0;
static volatile uint32_t step_last_time = 0;
static volatile uint8_t step_confirm = 0;  // consecutive counter

// Debug exports for UI display
volatile int32_t g_step_mag = 0;
volatile int32_t g_step_x_hat = 0;
volatile int8_t  g_step_ped_flag = 0;

// I2C error tracking (for debugging)
static uint32_t i2c_error_count = 0;

// ============================================
// Pedometer Algorithm v27: Fixed Consecutive Confirm
//
// Fixes the critical bug in v26: confirm counter was NOT reset
// when mag fell between 16500 and 18000. Noise could accumulate
// across multiple random spikes and trigger false steps.
//
// v27 fix: confirm resets to 0 on ANY sample not exceeding threshold.
// Only truly consecutive samples above threshold can trigger a step.
//
// Also: integer square comparison replaces sqrtf (no FPU needed).
// ============================================
#define STEP_THRESHOLD          18000   // trigger threshold
#define STEP_THRESHOLD_SQ       (18000LL * 18000LL)  // 324000000, for integer compare
#define STEP_CONFIRM_COUNT      3       // require 3 consecutive samples
#define STEP_DEBOUNCE_MS        200     // min time between steps

// ============================================
// I2C helpers with error checking (Fix #1 from AI review)
// ============================================
static uint8_t MPU6050_WriteReg(uint8_t reg, uint8_t data) {
    uint8_t buf[2] = {reg, data};
    HAL_StatusTypeDef status = HAL_I2C_Master_Transmit(
        mpu6050_i2c, MPU6050_ADDR, buf, 2, 100);
    if (status != HAL_OK) {
        i2c_error_count++;
        return 0;  // fail
    }
    return 1;  // success
}

static uint8_t MPU6050_ReadReg(uint8_t reg, uint8_t *data) {
    HAL_StatusTypeDef status = HAL_I2C_Master_Transmit(
        mpu6050_i2c, MPU6050_ADDR, &reg, 1, 100);
    if (status != HAL_OK) {
        i2c_error_count++;
        return 0;
    }
    status = HAL_I2C_Master_Receive(
        mpu6050_i2c, MPU6050_ADDR, data, 1, 100);
    if (status != HAL_OK) {
        i2c_error_count++;
        return 0;
    }
    return 1;
}

static uint8_t MPU6050_ReadRegs(uint8_t reg, uint8_t *data, uint8_t len) {
    HAL_StatusTypeDef status = HAL_I2C_Master_Transmit(
        mpu6050_i2c, MPU6050_ADDR, &reg, 1, 100);
    if (status != HAL_OK) {
        i2c_error_count++;
        return 0;
    }
    status = HAL_I2C_Master_Receive(
        mpu6050_i2c, MPU6050_ADDR, data, len, 100);
    if (status != HAL_OK) {
        i2c_error_count++;
        return 0;
    }
    return 1;
}

// ============================================
// Public API
// ============================================
void MPU6050_Init(I2C_HandleTypeDef *hi2c) {
    mpu6050_i2c = hi2c;
    
    HAL_Delay(100);
    
    // Reset device
    MPU6050_WriteReg(MPU6050_REG_PWR_MGMT_1, 0x80);
    HAL_Delay(100);
    
    // Wake up
    MPU6050_WriteReg(MPU6050_REG_PWR_MGMT_1, 0x00);
    HAL_Delay(10);
    
    // Configure: 1kHz sample, DLPF 42Hz, +-2g accel, +-250dps gyro
    MPU6050_WriteReg(MPU6050_REG_SMPLRT_DIV, 0x00);
    MPU6050_WriteReg(MPU6050_REG_CONFIG, 0x03);
    MPU6050_WriteReg(MPU6050_REG_GYRO_CONFIG, 0x00);
    MPU6050_WriteReg(MPU6050_REG_ACCEL_CONFIG, 0x00);
    
    // Verify WHO_AM_I (Fix #7 from AI review)
    uint8_t whoami = 0;
    MPU6050_ReadReg(MPU6050_REG_WHO_AM_I, &whoami);
    if (whoami != 0x68) {
        // Device not responding correctly
        // Could set a flag here, but for now just continue
    }
    
    StepCounter_Init();
}

uint8_t MPU6050_ReadWhoAmI(void) {
    uint8_t data = 0;
    MPU6050_ReadReg(MPU6050_REG_WHO_AM_I, &data);
    return data;
}

void MPU6050_ReadAccel(int16_t *ax, int16_t *ay, int16_t *az) {
    uint8_t buf[6];
    if (!MPU6050_ReadRegs(MPU6050_REG_ACCEL_XOUT_H, buf, 6)) {
        // I2C error: keep previous values to avoid glitches
        return;
    }
    *ax = (int16_t)((buf[0] << 8) | buf[1]);
    *ay = (int16_t)((buf[2] << 8) | buf[3]);
    *az = (int16_t)((buf[4] << 8) | buf[5]);
}

void MPU6050_ReadGyro(int16_t *gx, int16_t *gy, int16_t *gz) {
    uint8_t buf[6];
    if (!MPU6050_ReadRegs(MPU6050_REG_GYRO_XOUT_H, buf, 6)) {
        return;
    }
    *gx = (int16_t)((buf[0] << 8) | buf[1]);
    *gy = (int16_t)((buf[2] << 8) | buf[3]);
    *gz = (int16_t)((buf[4] << 8) | buf[5]);
}

float MPU6050_ReadTemp(void) {
    uint8_t buf[2];
    if (!MPU6050_ReadRegs(MPU6050_REG_TEMP_OUT_H, buf, 2)) {
        return g_mpu_temp;  // keep previous on error
    }
    int16_t raw = (int16_t)((buf[0] << 8) | buf[1]);
    g_mpu_temp = (raw / 340.0f) + 36.53f - 22.0f;
    return g_mpu_temp;
}

// ============================================
// Step Counter (v27)
// ============================================
void StepCounter_Init(void) {
    step_count = 0;
    step_last_time = 0;
    step_confirm = 0;
}

void StepCounter_Update(int16_t ax, int16_t ay, int16_t az) {
    // Integer square magnitude for comparison (no sqrtf needed)
    int64_t mag_sq = (int64_t)ax * ax + (int64_t)ay * ay + (int64_t)az * az;
    
    // Compute actual magnitude for display (still needs sqrt, but only for UI)
    int32_t mag = (int32_t)sqrtf((float)mag_sq);
    g_step_mag = mag;  // display actual magnitude (16900, not 285M)
    
    // Consecutive confirm counter (Fix #3 from AI review)
    // CRITICAL: any sample NOT exceeding threshold resets counter
    if (mag_sq > STEP_THRESHOLD_SQ) {
        step_confirm++;
    } else {
        step_confirm = 0;  // reset on ANY non-exceeding sample
    }
    
    // Display confirm count (clamp to 9)
    g_step_x_hat = (step_confirm > 9) ? 9 : step_confirm;
    
    uint32_t now = HAL_GetTick();
    
    // Step detected: confirmed AND debounce OK
    if (step_confirm >= STEP_CONFIRM_COUNT &&
        (now - step_last_time) > STEP_DEBOUNCE_MS) {
        step_count++;
        step_last_time = now;
        step_confirm = 0;  // reset after counting
        
        // DEBUG: send actual confirm count (Fix #4 from AI review)
        char dbg[64];
        int actual_confirm = STEP_CONFIRM_COUNT;  // was STEP_CONFIRM_COUNT at trigger
        sprintf(dbg, "STEP! sq=%ld confirm=%d\r\n", (long)mag_sq, actual_confirm);
        Bluetooth_SendString(dbg);
    }
}

uint32_t StepCounter_GetCount(void) {
    return step_count;
}

void StepCounter_Reset(void) {
    step_count = 0;
    step_last_time = 0;
    step_confirm = 0;
}
